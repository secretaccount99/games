<!DOCTYPE html>
<html lang="en-us">
  <head>
    <base href="https://cdn.jsdelivr.net/gh/secretaccount99/games@main/">
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>Google Classroom</title>
    <link rel="icon" type="image/png" href="https://ssl.gstatic.com/classroom/favicon.png">
    <style>
      html, body { background: #000; width: 100%; height: 100%; padding: 0; margin: 0; overflow: hidden; }
      #unity-container { width: 100%; height: 100%; position: relative; display: flex; align-items: center; justify-content: center; }
      #unity-canvas { width: 960px; height: 600px; background: #231f20; }
      #loading-text { position: absolute; color: white; font-family: cursive; font-size: 30px; text-align: center; z-index: 10; }
    </style>
  </head>
  <body>
    <div id="unity-container">
      <div id="loading-text">INITIALIZING...</div>
      <canvas id="unity-canvas" tabindex="-1"></canvas>
    </div>

    <script>
    const loadingText = document.querySelector("#loading-text");
    const canvas = document.querySelector("#unity-canvas");
    let loadedBytes = 0;
    const totalSizeMB = 139.53;

    // --- 1. THE CHUNK LOADER (Fixed to prevent auto-download) ---
    async function fetchWithProgress(url) {
      const response = await fetch(url);
      const reader = response.body.getReader();
      let chunks = [];
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        loadedBytes += value.length;
        chunks.push(value);
        let mbDone = (loadedBytes / (1024 * 1024)).toFixed(2);
        loadingText.textContent = `LOADING: ${mbDone} MB / ${totalSizeMB} MB`;
      }
      return new Uint8Array(await new Blob(chunks).arrayBuffer());
    }

    async function mergeFiles(fileParts) {
      const buffers = await Promise.all(fileParts.map(part => fetchWithProgress(part)));
      // Setting the type to octet-stream helps prevent the browser from "previewing" or downloading it
      const mergedBlob = new Blob(buffers, { type: 'application/octet-stream' });
      return URL.createObjectURL(mergedBlob);
    }

    function getParts(file, start, end) {
      let parts = [];
      for (let i = start; i <= end; i++) { parts.push(file + ".part" + i); }
      return parts;
    }

    // --- 2. START THE ENGINE ---
    (async () => {
      try {
        const [dataUrl, wasmUrl, webmUrl] = await Promise.all([
          mergeFiles(getParts("Build/fnae.data", 1, 3)),
          mergeFiles(getParts("Build/fnae.wasm", 1, 2)),
          mergeFiles(getParts("StreamingAssets/202512191935.webm", 1, 3))
        ]);

        // Mouse Lock Logic (Triggered by clicking the game)
        canvas.addEventListener('click', () => {
          if (document.pointerLockElement !== canvas) {
            canvas.requestPointerLock();
          }
        });

        // Panic Button (-)
        document.addEventListener('keydown', (e) => {
          if (e.key === '-') window.location.href = "https://classroom.google.com";
        });

        // Unity Configuration
        const config = {
          dataUrl: dataUrl,
          frameworkUrl: "Build/fnae.framework.js",
          codeUrl: wasmUrl,
          streamingAssetsUrl: "StreamingAssets",
          companyName: "DefaultCompany",
          productName: "fnae",
          productVersion: "1.0",
        };

        const script = document.createElement("script");
        script.src = "Build/fnae.loader.js";
        script.onload = () => {
          createUnityInstance(canvas, config, (progress) => {
            // This is for the Unity internal load bar if it exists
          }).then(() => {
            loadingText.remove();
          });
        };
        document.body.appendChild(script);

      } catch (err) {
        loadingText.textContent = "ERROR LOADING PARTS. REFRESH PAGE.";
        console.error(err);
      }
    })();
    </script>
  </body>
</html>
